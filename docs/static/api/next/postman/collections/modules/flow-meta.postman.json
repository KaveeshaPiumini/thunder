              "body": "{\n  \"isRegistrationFlowEnabled\": \"<boolean>\",\n  \"isRecoveryFlowEnabled\": \"<boolean>\",\n  \"design\": {\n    \"theme\": {\n      \"amet_682\": \"exercitation ut\"\n    },\n    \"layout\": {\n      \"dolord\": -63589928,\n      \"occaecat567\": 72927432.09393221,\n      \"quif0\": 75340288.65067041,\n      \"aliquab\": false\n    }\n  },\n  \"i18n\": {\n    \"languages\": [\n      \"<string>\",\n      \"<string>\"\n    ],\n    \"language\": \"<string>\",\n    \"translations\": {\n      \"dolore_94\": {\n        \"deserunt_e\": \"<string>\"\n      },\n      \"exercitation_2c\": {\n        \"exb\": \"<string>\",\n        \"consectetur_0d\": \"<string>\"\n      },\n      \"Duisbd\": {\n        \"aliquip41\": \"<string>\",\n        \"amet_4a\": \"<string>\",\n        \"est_6\": \"<string>\"\n      },\n      \"dolor55\": {\n        \"magnac\": \"<string>\"\n      }\n    },\n    \"totalResults\": \"<integer>\"\n  },\n  \"application\": {\n    \"id\": \"<uuid>\",\n    \"name\": \"<string>\",\n    \"description\": \"<string>\",\n    \"logoUrl\": \"<uri>\",\n    \"url\": \"<uri>\",\n    \"tosUri\": \"<uri>\",\n    \"policyUri\": \"<uri>\"\n  },\n  \"ou\": {\n    \"id\": \"<uuid>\",\n    \"handle\": \"<string>\",\n    \"name\": \"<string>\",\n    \"description\": \"<string>\",\n    \"logoUrl\": \"<uri>\",\n    \"tosUri\": \"<uri>\",\n    \"policyUri\": \"<uri>\",\n    \"cookiePolicyUri\": \"<uri>\"\n  }\n}",
